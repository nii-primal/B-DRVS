# B-DRVS Dashboard Environment Variables
# Copy to .env.local and adjust for your environment.

# REST Gateway base URL. In development this is proxied through Vite (see vite.config.js)
# so you can leave it as /api. For a production build pointing at a remote gateway,
# set this to the full origin, e.g. http://10.0.0.5:3000/api
VITE_API_BASE_URL=/api

# Polling interval for live data refresh (milliseconds)
VITE_POLL_INTERVAL_MS=15000

# Optional dashboard label shown in the header
VITE_DEPLOYMENT_LABEL=Prototype · UMaT
